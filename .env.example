# .env.example — copy to .env and fill in values
# cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# NEVER commit a real .env or real keys. This template holds placeholders only.

# OpenRouter — inference and baseline evaluation
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_BASELINE=qwen/qwen3-8b
# Judge: a SINGLE, non-Qwen (≠ model under test), pinned model — used identically
# on both sides (CLAUDE.md HARD RULE #3). There is intentionally NO cross-model
# fallback: swapping judges per call makes the judge a non-deterministic mixture
# and breaks comparability (Lesson #18).
#   We use deepseek-v4-FLASH (not -pro) by EVIDENCE: across past CB runs pro ran as
#   a heavy reasoning model and overflowed JUDGE_MAX_TOKENS (28% null-content
#   errors; reasoning seen up to 1178 tokens, so even 1024 is unsafe for pro),
#   while flash reasons far less (≤842 tokens) → ~0% errors at JUDGE_MAX_TOKENS=1024.
#   Flash is the weaker tier, so its ABSOLUTE numbers must be justified by the κ
#   human-agreement check (scripts/08_judge_validation.py, EVALUATION_PROTOCOL §1);
#   the internal baseline→fine-tuned delta is rigorous regardless (same judge both
#   sides). If κ is unsatisfactory, escalate to pro + non-reasoning provider pinning.
OPENROUTER_MODEL_JUDGE=deepseek/deepseek-v4-flash

# HuggingFace — model and dataset upload
HF_TOKEN=hf_REPLACE_ME
HF_REPO_ID=openscriptura/qwen3-8b-reformed-pt-br-v0.1
HF_DATASET_REPO=openscriptura/reformed-theology-v1

# Reproducibility
SEED=42

# Logging
LOG_LEVEL=INFO

# Cost guardrails — hard stop if accumulated spend exceeds this value (USD)
COST_LIMIT_USD_PHASE0=5.00
COST_LIMIT_USD_PHASE4=5.00
COST_LIMIT_USD_TRANSLATE=5.00

# pt-BR SECONDARY eval track (translate_benchmark.py). Strong multilingual model;
# default deepseek-v4-pro. The translated benchmark is NOT leaderboard-comparable
# (English stays the headline) — it measures the real pt-BR deployment.
OPENROUTER_MODEL_TRANSLATE=deepseek/deepseek-v4-pro
