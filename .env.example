# .env.example — copy to .env and fill in values
# cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# NEVER commit a real .env or real keys. This template holds placeholders only.

# OpenRouter — inference and baseline evaluation
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_BASELINE=qwen/qwen3-8b
# Judge: use a STRONG, NON-Qwen (≠ model under test), PINNED model — see
# docs/EVALUATION_PROTOCOL.md. "flash" is too weak for a defensible judge;
# prefer a full/frontier tier and pin a dated snapshot for reproducibility.
OPENROUTER_MODEL_JUDGE=deepseek/deepseek-v4

# HuggingFace — model and dataset upload
HF_TOKEN=hf_REPLACE_ME
HF_REPO_ID=openscriptura/qwen3-8b-reformed-pt-br-v0.1
HF_DATASET_REPO=openscriptura/reformed-theology-v1

# Reproducibility
SEED=42

# Logging
LOG_LEVEL=INFO

# Cost guardrails — hard stop if accumulated spend exceeds this value (USD)
COST_LIMIT_USD_PHASE0=5.00
COST_LIMIT_USD_PHASE4=5.00
